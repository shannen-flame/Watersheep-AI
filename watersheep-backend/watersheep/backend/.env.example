# =============================================================================
# Watersheep Backend - Environment Variables
# Copy this file to .env and fill in your values.
# =============================================================================

# --- Gemini API (required for cloud AI) ---
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# --- Gemini model names ---
# gemini-2.0-flash  -> good balance of speed and free-tier quota (RECOMMENDED)
# gemini-1.5-flash  -> higher free-tier quota, slightly older
# gemini-2.5-flash  -> most capable, lowest free-tier quota (avoid on free tier)
GEMINI_TEXT_MODEL=gemini-2.0-flash
GEMINI_VISION_MODEL=gemini-2.0-flash

# --- Primary LLM provider (ollama | gemini) ---
# Set to "ollama" if you have Ollama running locally (zero quota cost).
# Falls back to "gemini" when Ollama is unavailable.
WATERSHEEP_LLM_PROVIDER=ollama
WATERSHEEP_LLM_MODEL=llama3.2:3b
# Used when the user says "my city" or "here" for weather.
WATERSHEEP_DEFAULT_CITY=
# Lets the assistant use internet search for current/live questions.
WATERSHEEP_ENABLE_WEB_SEARCH=true
# Search provider: auto | brave | tavily | serpapi | duckduckgo
# auto tries configured paid/free APIs first, then falls back to DuckDuckGo.
WATERSHEEP_SEARCH_PROVIDER=auto
WATERSHEEP_SEARCH_MAX_RESULTS=5
WATERSHEEP_SEARCH_FETCH_PAGES=false
WATERSHEEP_SEARCH_USE_LLM_SUMMARY=false

# --- Internet search providers (optional) ---
# Add one or more keys. The code is modular so providers can be swapped later.
BRAVE_SEARCH_API_KEY=
TAVILY_API_KEY=
SERPAPI_API_KEY=
BING_SEARCH_API_KEY=
GOOGLE_CSE_API_KEY=
GOOGLE_CSE_CX=
EXA_API_KEY=

# --- Ollama (optional local LLM - no API key needed) ---
# Install: https://ollama.com  then: ollama pull llama3.2:3b
# The backend (running on the Mac) calls Ollama on localhost. The iPhone never
# talks to Ollama directly; it talks to the backend over the LAN.
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_TEXT_MODEL=llama3.2:3b
OLLAMA_VISION_MODEL=gemma3
OLLAMA_TIMEOUT_SECONDS=60
# Keep this off unless you explicitly want local Ollama to guess after Gemini
# and OpenRouter both fail. Off is safer for "what am I looking at?".
WATERSHEEP_ENABLE_OLLAMA_VISION_FALLBACK=false

# --- OpenRouter (optional vision fallback when Gemini fails) ---
# Get a key at: https://openrouter.ai/keys
# Free models: meta-llama/llama-3.2-3b-instruct:free, google/gemma-2-9b-it:free
# Paid recommended: openai/gpt-4o-mini (cheap, fast, good quality)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_VISION_MODEL=openai/gpt-4o-mini
OPENROUTER_REFERER=https://watersheep.local

# --- Vision quota cooldown ---
# Seconds to pause Gemini vision after a 429 quota-exceeded error.
# 60s is the safe minimum for the Gemini free tier.
VISION_COOLDOWN_SECONDS=60

# --- Image guards ---
# Hard limits applied to uploaded images before any model call.
WATERSHEEP_MAX_IMAGE_BYTES=8388608
WATERSHEEP_MAX_IMAGE_PIXELS=24000000
WATERSHEEP_MAX_IMAGE_DIMENSION=8192

# --- Server ---
WATERSHEEP_HOST=0.0.0.0
WATERSHEEP_PORT=8000
WATERSHEEP_ENV=development

# --- CORS ---
# Comma-separated list of origins that are allowed to call the backend.
# Leave it as "*" only in development. For production, list explicit origins:
#   WATERSHEEP_CORS_ORIGINS=https://watersheep.app,https://example.com
WATERSHEEP_CORS_ORIGINS=*

# --- Debug surfaces ---
# Set to false in production to hide /api/events and similar diagnostic routes.
WATERSHEEP_DEBUG_ENDPOINTS=true
