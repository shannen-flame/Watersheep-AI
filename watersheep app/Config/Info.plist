<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CFBundleDevelopmentRegion</key>
    <string>$(DEVELOPMENT_LANGUAGE)</string>
    <key>CFBundleDisplayName</key>
    <string>Watersheep</string>
    <key>CFBundleExecutable</key>
    <string>$(EXECUTABLE_NAME)</string>
    <key>CFBundleIdentifier</key>
    <string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
    <key>CFBundleInfoDictionaryVersion</key>
    <string>6.0</string>
    <key>CFBundleName</key>
    <string>Watersheep</string>
    <key>CFBundlePackageType</key>
    <string>$(PRODUCT_BUNDLE_PACKAGE_TYPE)</string>
    <key>CFBundleShortVersionString</key>
    <string>$(MARKETING_VERSION)</string>
    <key>CFBundleURLTypes</key>
    <array>
        <dict>
            <key>CFBundleTypeRole</key>
            <string>Editor</string>
            <key>CFBundleURLName</key>
            <string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
            <key>CFBundleURLSchemes</key>
            <array>
                <string>watersheep</string>
            </array>
        </dict>
    </array>
    <key>CFBundleVersion</key>
    <string>$(CURRENT_PROJECT_VERSION)</string>
    <key>BackendBaseURL</key>
    <string>http://192.168.1.224:8000</string>
    <key>MWDAT</key>
    <dict>
        <key>AppLinkURLScheme</key>
        <string>watersheep://</string>
        <key>ClientToken</key>
        <string>$(CLIENT_TOKEN)</string>
        <key>MetaAppID</key>
        <string>$(META_APP_ID)</string>
        <key>TeamID</key>
        <string>$(DEVELOPMENT_TEAM)</string>
    </dict>
    <key>NSBluetoothAlwaysUsageDescription</key>
    <string>Needed to connect to Meta AI Glasses</string>
    <key>NSBluetoothPeripheralUsageDescription</key>
    <string>Needed to connect to Meta AI Glasses</string>
    <key>NSCameraUsageDescription</key>
    <string>Watersheep uses the camera for live OCR during debugging.</string>
    <key>NSAppTransportSecurity</key>
    <dict>
        <!--
            We do not allow arbitrary HTTP loads. The app only needs to talk
            to the backend over the local Wi-Fi LAN, and Apple already grants
            HTTP for that case via NSAllowsLocalNetworking. Cloud calls
            (Gemini etc.) are made by the backend, not by the iOS app.
        -->
        <key>NSAllowsLocalNetworking</key>
        <true/>
    </dict>
    <key>NSLocalNetworkUsageDescription</key>
    <string>Watersheep connects to a local backend server on your Wi-Fi network to process AI requests.</string>
    <key>NSMicrophoneUsageDescription</key>
    <string>Watersheep uses the microphone to listen for your voice commands.</string>
    <key>NSPhotoLibraryAddUsageDescription</key>
    <string>This app needs access to save photos captured from your glasses.</string>
    <key>NSSpeechRecognitionUsageDescription</key>
    <string>Watersheep uses speech recognition to convert your voice into assistant commands.</string>
    <key>UIApplicationSceneManifest</key>
    <dict>
        <key>UIApplicationSupportsMultipleScenes</key>
        <false/>
    </dict>
    <key>UIApplicationSupportsIndirectInputEvents</key>
    <true/>
    <key>UIBackgroundModes</key>
    <array>
        <string>bluetooth-peripheral</string>
        <string>external-accessory</string>
    </array>
    <key>UILaunchScreen</key>
    <dict/>
    <key>UISupportedExternalAccessoryProtocols</key>
    <array>
        <string>com.meta.ar.wearable</string>
    </array>
    <key>UISupportedInterfaceOrientations</key>
    <array>
        <string>UIInterfaceOrientationPortrait</string>
    </array>
    <key>UISupportedInterfaceOrientations~ipad</key>
    <array>
        <string>UIInterfaceOrientationPortrait</string>
        <string>UIInterfaceOrientationPortraitUpsideDown</string>
        <string>UIInterfaceOrientationLandscapeLeft</string>
        <string>UIInterfaceOrientationLandscapeRight</string>
    </array>
</dict>
</plist>
